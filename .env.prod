###############################################
# 사주입문플랫폼 Production 환경 설정
# 서버: EC2 3.39.42.53
# 배포 경로: /var/www/php/saju_learning/shared/.env 에 복사하여 사용
# 아래 [TODO] 항목을 실제 값으로 교체할 것
###############################################

APP_NAME="사주입문플랫폼"
APP_ENV=production
APP_KEY=base64:jiiPMEisqsE7Oitaam6fSSeAG6tO+XiTUeFxc1Q07AE=
APP_DEBUG=false
APP_URL=https://sajuedu.donggyu.link

APP_LOCALE=ko
APP_FALLBACK_LOCALE=ko
APP_FAKER_LOCALE=ko_KR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

#----------------------------------------------
# 로깅
#----------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

#----------------------------------------------
# 데이터베이스 (MySQL / MariaDB)
#----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=13306
DB_DATABASE=saju_intro_platform
DB_USERNAME=saju_intro
DB_PASSWORD=saju123!@
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

#----------------------------------------------
# 세션 / 캐시 / 큐
#----------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

#----------------------------------------------
# 메일 (필요 시 SMTP로 변경)
#----------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

#----------------------------------------------
# AWS S3 (획순 이미지 등 파일 저장, 필요 시 설정)
#----------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

#----------------------------------------------
# Vite
#----------------------------------------------
VITE_APP_NAME="${APP_NAME}"
